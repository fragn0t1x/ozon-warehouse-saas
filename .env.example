# Database
DATABASE_URL=postgresql+asyncpg://ozon:ozon@postgres:5432/ozon

# Redis
REDIS_URL=redis://redis:6379

# App
APP_ENV=development
API_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001
SQL_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE_SECONDS=1800
AUTO_CREATE_SCHEMA=true

# Auth
JWT_SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Telegram
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=

# Encryption (сгенерируйте ключ командой: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your_encryption_key_here

# Ozon (для тестового магазина)
OZON_CLIENT_ID=your_ozon_client_id
OZON_API_KEY=your_ozon_api_key
OZON_RATE_LIMIT_PER_CLIENT_ID=45
OZON_BUNDLE_RATE_LIMIT_PER_CLIENT_ID=4
OZON_STOCKS_RATE_LIMIT_PER_CLIENT_ID=2
OZON_BUNDLE_MIN_INTERVAL_MS=600
OZON_STOCKS_MIN_INTERVAL_MS=800
OZON_STOCKS_RETRY_BASE_SECONDS=3
OZON_STOCKS_429_COOLDOWN_SECONDS=12
OZON_STOCKS_5XX_COOLDOWN_SECONDS=20
OZON_RATE_LIMIT_ALERT_THRESHOLD_PER_MINUTE=10
